# Copie para .env e preencha. NÃO comite o .env (já está no .gitignore).
# Para desenvolvimento local você pode carregar com:  python -m dotenv ... ou
# definindo as variáveis no terminal antes de rodar.

# Chave da API Gemini — crie em https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Opcional: modelo Gemini (padrão: gemini-2.5-flash, leve e barato)
GEMINI_MODELO=gemini-2.5-flash

# Opcional: provedor da LLM
#   auto     -> Gemini se houver chave, senão LM Studio local (padrão)
#   gemini   -> força Gemini
#   lmstudio -> força LM Studio local
LLM_PROVIDER=auto
