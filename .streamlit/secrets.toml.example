# Exemplo de segredos para deploy no Streamlit Community Cloud.
# No painel do app: Settings -> Secrets, cole o conteúdo abaixo já preenchido.
# Localmente: copie para .streamlit/secrets.toml (ignorado pelo git).

GEMINI_API_KEY = "cole-sua-chave-aqui"

# Opcionais:
# GEMINI_MODELO = "gemini-2.5-flash"
# LLM_PROVIDER = "gemini"
